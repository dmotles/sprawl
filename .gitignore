# Sprawl binary (generated by make build)
sprawl
# Matrix per-row test-tag builds (scripts/e2e-matrix.sh creates these
# for rows with needs_build_tags=sprawl_test)
sprawl-matrix-*

# Hosttest binary (generated by go build ./cmd/hosttest/)
hosttest

# OS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# Sprawl runtime state (config.yaml is tracked, everything else is ignored)
.sprawl/*
!.sprawl/config.yaml

.claude/settings.local.json
.codex
CLAUDE.local.md

# Local secrets (CLAUDE_CODE_OAUTH_TOKEN, ANTHROPIC_API_KEY, etc.) — see CLAUDE.md
.env

# Terraform / IaC (QUM-870) — nothing instance-specific or stateful enters the tree.
# Real values live ONLY in gitignored tfvars / backend-config / .env; committed IaC
# is fully parameterized. .terraform.lock.hcl is intentionally NOT ignored (tracked).
*.tfvars
*.tfvars.json
*.tfstate
*.tfstate.*
.terraform/
backend-config*.hcl

# az / credential scratch produced during bootstrap
*.azcreds
az-scratch/
bootstrap.env
# Operator runbooks that may reference corporate specifics — gitignored.
# Committed docs are the sanitized README.md; *.local.md stays out of the tree.
deploy/hub/**/*.local.md
