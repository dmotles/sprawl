# bootstrap.env.example (QUM-870) — TEMPLATE, placeholders only.
#
# Copy to `bootstrap.env` (GITIGNORED) and fill in real values. NEVER commit
# bootstrap.env or put real values in this .example file — this repo is PUBLIC.
#
#   cp bootstrap.env.example bootstrap.env
#   $EDITOR bootstrap.env
#   ./bootstrap.sh
#
# This file is sourced by bootstrap.sh as bash, so quoting rules apply.

# Azure subscription to pin EVERY az/terraform operation to. Without this, az
# falls back to the CLI's active subscription — which once landed resources in
# the wrong subscription. A corporate identifier: gitignored, NEVER committed.
# bootstrap.sh exports it as ARM_SUBSCRIPTION_ID so the Terraform azurerm
# backend/provider bind the same subscription.
SUBSCRIPTION_ID="<azure-subscription-id>"

# Dedicated, NET-NEW resource group for the Terraform state backend ONLY.
# Do not reuse an existing corporate resource group.
STATE_RG="<state-backend-resource-group>"

# Globally-unique storage account name (3-24 lowercase alphanumerics).
STATE_STORAGE_ACCOUNT="<state-backend-storage-account>"

# Blob container that holds the state blobs. "tfstate" is a fine default.
STATE_CONTAINER="tfstate"

# Azure region. A parameter — never hardcode a region in committed IaC.
LOCATION="<your-region>"

# Optional. Storage redundancy SKU (default Standard_LRS if unset).
# STATE_SKU="Standard_LRS"

# Mandatory resource tags — applied to the RG and the storage account.
# Bash array of key=value pairs; values with spaces must be quoted.
# Real values are policy-defined and live ONLY here (gitignored), never committed.
RESOURCE_TAGS=(
	"owner=<owner>"
	"long_running=<true|false>"
	"department=<department>"
	"purpose=<purpose>"
)
