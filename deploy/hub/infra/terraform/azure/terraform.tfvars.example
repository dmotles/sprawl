# terraform.tfvars.example (QUM-879) — TEMPLATE, placeholders only.
#
# Copy to `terraform.tfvars` (GITIGNORED) and fill in real values. NEVER commit
# terraform.tfvars or put real values here — this repo is PUBLIC and the target
# is CORPORATE Azure.
#
#   cp terraform.tfvars.example terraform.tfvars
#   $EDITOR terraform.tfvars
#   terraform init -backend-config=backend-config.hcl
#   terraform plan  -var-file=terraform.tfvars    # pin --subscription via the tfvar below
#   terraform apply -var-file=terraform.tfvars -var container_image=<acr>.azurecr.io/hubd:<tag>

# Pins EVERY resource to this subscription (never the CLI's active default).
subscription_id = "<azure-subscription-id>"
location        = "<your-region>"

# Dedicated, stand-alone Phase-0 hub RG — NOT the state-backend RG, NOT the spike RG.
resource_group_name = "<hub-resource-group>"

# Container host glue.
log_analytics_name = "<log-analytics-workspace-name>"
environment_name   = "<container-apps-environment-name>"
acr_name           = "<acr-name-5-50-lowercase-alnum>"
container_app_name = "<container-app-name>"
uami_name          = "<user-assigned-identity-name>"

# Managed Postgres (smallest burstable by default; override sizes as needed).
postgres_server_name = "<postgres-flexible-server-name>"
# postgres_size          = "B_Standard_B1ms"
# postgres_version       = "16"
# backup_retention_days  = 7

# Blob object store.
storage_account_name = "<storage-account-3-24-lowercase-alnum>"
# blob_lifecycle_days  = 0   # 0 = keep-forever backstop; set >0 to expire old blobs

# Secrets store.
key_vault_name = "<key-vault-name-3-24-chars>"

# Optional app config.
# hub_url        = ""      # leave empty; set out-of-band once a custom domain exists
# debug_endpoint = false

# Mandatory policy tags — real values are gitignored-config-only. Azure tags do
# NOT inherit, so the root applies this exact map to the RG AND every resource.
tags = {
  owner        = "<owner>"
  long_running = "<true|false>"
  department   = "<department>"
  purpose      = "<purpose>"
}

# ---------------------------------------------------------------------------
# SECRETS PROVISIONING (Phase-0) — read before you apply
# ---------------------------------------------------------------------------
# hubd resolves all secret material at boot via the P0-2 secrets seam
# (gocloud.dev/secrets + gocloud.dev/blob) and env. NO secret VALUE is ever a
# Terraform input variable or committed. Values reach the container as Key Vault
# references, resolved by the app's user-assigned managed identity.
#
# Two of the keys are GENERATED IN TERRAFORM (random_bytes) with the CORRECT
# encoding per slot, so an operator can't fat-finger the alphabet. THE TWO KEYS
# USE OPPOSITE BASE64 ALPHABETS — this is the single most important foot-gun:
#
#   SPRAWL_HUB_SECRET_URL  (host-token pepper keeper, base64key://<key>)
#     -> URL-SAFE base64. gocloud localsecrets uses base64.URLEncoding.
#        A standard-base64 key containing '+' or '/' silently decodes to the
#        WRONG 32 bytes (a '/' truncates the URL host), so minted host tokens
#        won't verify. TF translates the alphabet (+/ => -_) automatically.
#        If you ever mint one by hand instead:
#          openssl rand -base64 32 | tr '+/' '-_'
#        This value MUST be IDENTICAL between hubd and `sprawl hub token create`.
#
#   SPRAWL_HUB_COOKIE_KEY  (browser cookie-signing key)
#     -> STANDARD base64, >=32 decoded bytes. login.go uses base64.StdEncoding.
#        A URL-safe value silently DISABLES browser login. By hand:
#          openssl rand -base64 32
#
# The other two secret slots are injected OUT-OF-BAND after apply (never in TF):
#
#   SPRAWL_HUB_DSN        -> the Postgres DSN, generated by the database module
#                            (admin password via random_password) and written to
#                            Key Vault as secret "hub-dsn" by the root.
#   SPRAWL_HUB_LOGIN_TOKEN-> any non-empty shared string (browser login). Empty
#                            placeholder slot "hub-login-token" is provisioned by
#                            the secrets module; set the real value after apply:
#          az keyvault secret set --vault-name <kv> --name hub-login-token \
#            --value "<a-non-empty-shared-string>" --subscription <sub>
#
# See ./README.md for the full env inventory and the apply runbook.
