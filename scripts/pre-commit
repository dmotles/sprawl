#!/usr/bin/env bash
set -e

# QUM-808: refuse non-root agent commits to shared 'main' before anything else.
# Resolve the guard relative to this hook's own real path (this script is
# symlinked into the shared .git/hooks dir, so readlink -f lands in the main
# checkout's scripts/ — which always has the guard, regardless of which
# worktree is committing). Branch detection inside the guard still uses the
# committing worktree's HEAD via git, so this is both robust and correct.
here="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
"$here/guard-main-commit"

# QUM-836: git exports repo-scoping GIT_* vars (pointing at THIS repo's .git)
# into the hook environment. `make validate` runs `go test`, whose integration
# suites spawn nested `git` in throwaway temp repos; if they inherit these vars
# they resolve to the outer repo instead of their temp repo and fail. Unset them
# so validation runs with a clean git env. (Done AFTER the guard, which
# intentionally relies on the committing worktree's git context.)
unset GIT_DIR GIT_INDEX_FILE GIT_WORK_TREE GIT_OBJECT_DIRECTORY GIT_COMMON_DIR GIT_NAMESPACE GIT_PREFIX

echo "Running pre-commit validation..."
make validate
