#!/usr/bin/env bash
# run-claude — claude(1) launcher that hydrates auth env vars from $SPRAWL_ROOT/.env.
#
# Background (QUM-518): when an agent invokes `claude -p ...` from a Bash tool
# subshell, Claude Code sanitizes the subprocess env and strips
# $CLAUDE_CODE_OAUTH_TOKEN, leaving the inner claude unable to authenticate.
# This shim sources $SPRAWL_ROOT/.env (if present) so the token is restored
# before exec'ing the real claude binary.
#
# .env is local-only and gitignored. It typically contains:
#   CLAUDE_CODE_OAUTH_TOKEN=...
#   ANTHROPIC_API_KEY=...        # optional
#
# Usage:
#   SPRAWL_CLAUDE=$(pwd)/scripts/run-claude sprawl enter
set -euo pipefail

# Resolve sprawl root: $SPRAWL_ROOT if set, else the parent of this script's dir.
if [[ -n "${SPRAWL_ROOT:-}" ]]; then
  root="$SPRAWL_ROOT"
else
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  root="$(dirname "$script_dir")"
fi

env_file="$root/.env"
if [[ -f "$env_file" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "$env_file"
  set +a
fi

exec claude "$@"
